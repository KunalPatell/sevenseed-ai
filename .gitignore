# ── Secrets ──────────────────────────────────────────────────────────────────
# Never commit these. apps/sevenforce/.gitignore was missing the .env rule while
# apps/sevenforce/backend/.env holds ~20 live keys (GITHUB_TOKEN, OPENAI_API_KEY,
# BREVO/RESEND, ...). Covering it here closes that gap for every app at once.
.env
.env.*
!.env.example
*.pem
*credential*.json

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.sqlite3
db.sqlite3
db.sqlite3.bak

# ── Node / Next.js ───────────────────────────────────────────────────────────
node_modules/
.next/
out/
tsconfig.tsbuildinfo

# ── Local debug output ────────────────────────────────────────────────────────
_run_log.txt

# ── Built frontend copied into the backend at build time ─────────────────────
# Ensure backend/static is tracked so Render serves the compiled Next.js single-page applications
# apps/*/backend/static/
!apps/sevenforce/backend/static/

# ── Migration leftovers ──────────────────────────────────────────────────────
# The eight original per-app .git directories, moved aside during the monorepo
# migration. Kept on disk so nothing is lost, but not part of this repo.
_old-git/
