# ════════════════════════════════════════════════════════════════
#  COMONK AI — Free API Keys Guide
#  Copy this to .env and fill in your keys
# ════════════════════════════════════════════════════════════════

# ── LLM / AI Keys (at least 1 required) ─────────────────────────

# GROQ — FREE forever — Llama 3.3 70B (fastest free LLM)
# Sign up: console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here
# GROQ_MODEL=llama-3.3-70b-versatile

# GEMINI — FREE tier (15 requests/min, no daily limit)
# Sign up: aistudio.google.com → Get API key
# GEMINI_API_KEY=your_gemini_key_here

# MISTRAL — FREE tier (1 req/sec, limited)
# Sign up: console.mistral.ai
# MISTRAL_API_KEY=your_mistral_key_here

# OPENAI — Paid (optional, used as final fallback)
# OPENAI_API_KEY=your_openai_key_here

# ── Job Listings ─────────────────────────────────────────────────

# ADZUNA — FREE 1,000 requests/day — India job listings
# Sign up: developer.adzuna.com → Create App
# ADZUNA_APP_ID=your_app_id
# ADZUNA_API_KEY=your_api_key

# ── Learning & News ───────────────────────────────────────────────

# YOUTUBE DATA API v3 — FREE 10,000 units/day — Tutorial search
# Sign up: console.cloud.google.com → Enable YouTube Data API v3 → Create API Key
# YOUTUBE_API_KEY=your_youtube_key_here

# GNEWS — FREE 100 requests/day — Tech news
# Sign up: gnews.io → Free plan
# GNEWS_API_KEY=your_gnews_key_here

# NEWSAPI — FREE developer plan 100 req/day — Tech news
# Sign up: newsapi.org → Register → Get API Key
# NEWSAPI_KEY=your_newsapi_key_here

# ── Company / HR Research ─────────────────────────────────────────

# HUNTER.IO — FREE 25 searches/month — Find HR email patterns by domain
# Sign up: hunter.io → Dashboard → API Key
# HUNTER_API_KEY=your_hunter_key_here

# ── GitHub (optional — raises rate limit 60 → 5000 req/hr) ───────
# Sign up: github.com/settings/tokens → New classic token → (no special scope needed)
# GITHUB_TOKEN=your_github_pat_here

# ── Email Sending ────────────────────────────────────────────────

# SENDGRID — FREE 100 emails/day — For sending cold emails from the platform
# Sign up: sendgrid.com → Free plan → Settings → API Keys
# SENDGRID_API_KEY=your_sendgrid_key_here
# SENDGRID_FROM_EMAIL=your_verified_email@domain.com

# ── Server Config ────────────────────────────────────────────────
# PORT=8000
